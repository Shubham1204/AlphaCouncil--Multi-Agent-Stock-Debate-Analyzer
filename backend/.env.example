# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================
# One of: mock | bedrock | anthropic
#   mock      -> no API keys needed, deterministic offline responses (runs today)
#   bedrock   -> AWS Bedrock Converse API
#   anthropic -> direct Anthropic API
LLM_PROVIDER=mock

# ----- AWS Bedrock settings (used when LLM_PROVIDER=bedrock) -----------------
AWS_REGION=us-west-2
# Default model for all agents (an inference-profile id or model id you can access).
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8
# Optionally give the moderator/synthesizer a different model. Blank = reuse default.
BEDROCK_MODEL_ID_MODERATOR=
# Fallback model if the primary errors (throttle/access/etc.). Blank = no fallback.
BEDROCK_MODEL_ID_FALLBACK=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ----- Anthropic direct API (used when LLM_PROVIDER=anthropic) ---------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# ============================================================================
# MARKET DATA / NEWS (all optional; app degrades gracefully without them)
# ============================================================================
# Yahoo (prices/charts) and NSE (Indian corporate actions) need no key.
# These enrich fundamentals + news if provided:
FINNHUB_API_KEY=          # finnhub.io — US fundamentals + US/general news
GNEWS_API_KEY=            # gnews.io — company news by name (covers India + all markets)
ALPHAVANTAGE_API_KEY=
NEWSAPI_KEY=

# ============================================================================
# SERVER
# ============================================================================
HOST=0.0.0.0
PORT=8000
# Comma-separated allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex to allow a family of frontend origins (e.g. your CDN domain).
# Blank = default to allowing *.cloudfront.net.
CORS_ORIGIN_REGEX=

# Number of debate rounds (1-2 recommended)
DEBATE_ROUNDS=2

# ============================================================================
# OPTIONAL AUTH (OIDC / JWT) — gate the API behind a login
# ============================================================================
# When true, every /api and /ws request must carry a valid OIDC id_token
# (Authorization: Bearer <id_token>). Leave false for local/mock/public demo.
# Works with any OIDC provider (Cognito, Auth0, Okta, Google, Entra ID, ...).
REQUIRE_AUTH=false
# Your provider's issuer + JWKS URL (from its OIDC discovery document):
OIDC_ISSUER=
OIDC_JWKS_URL=
# Optional: restrict to specific audiences (client_ids), comma-separated.
# Blank = accept any valid token (still verifies signature + issuer + expiry).
OIDC_AUDIENCE=
