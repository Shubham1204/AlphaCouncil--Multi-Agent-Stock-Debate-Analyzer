        <!-- Legend -->
        <mxCell id="legend" value="Flow: User → Frontend (CloudFront) —SSE→ FastAPI (App Runner) → Orchestrator → 8 agents × Bedrock  +  Data/News/Corp-action sources.  3 phases: independent analysis → debate rounds → profile-weighted consensus.  All external sources fall back gracefully to synthetic." style="text;html=1;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="720" width="1470" height="40" as="geometry" />
