        <mxCell id="e_data_news" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="be_data" target="news">
