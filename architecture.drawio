<mxfile host="app.diagrams.net" agent="stock-debate-analyzer" version="24.0.0">
  <diagram id="stock-debate-arch" name="Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Multi-Agent Stock Debate Analyzer — Architecture" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="20" width="780" height="30" as="geometry" />
        </mxCell>

        <!-- ================= USER ================= -->
        <mxCell id="user" value="👤 User&#10;(browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="470" width="110" height="70" as="geometry" />
        </mxCell>

        <!-- ================= FRONTEND ================= -->
        <mxCell id="fe" value="FRONTEND — React + Vite + TypeScript&#10;hosted on CloudFront+S3 (public) " style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=13;fontStyle=1;align=center;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="220" y="330" width="330" height="330" as="geometry" />
        </mxCell>
        <mxCell id="fe_host" value="CloudFront + private S3 (OAC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="240" y="366" width="290" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fe_control" value="ControlPanel (ticker · agents · profile · rounds 1–2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="402" width="290" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fe_hook" value="useDebate() — SSE/POST client, parses events → state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="448" width="290" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fe_feed" value="DebateFeed · ConsensusPanel (live verdicts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="494" width="290" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fe_charts" value="TechnicalCharts (Recharts) · StockOverview · SidePanels · PDF export" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="540" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="fe_note" value="base './' · VITE_TRANSPORT=sse · VITE_API_BASE → App Runner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="240" y="596" width="290" height="40" as="geometry" />
        </mxCell>

        <!-- ================= BACKEND ================= -->
        <mxCell id="be" value="BACKEND — FastAPI (Python)  ·  AWS App Runner (Docker/ECR) " style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=13;fontStyle=1;align=center;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="150" width="500" height="500" as="geometry" />
        </mxCell>
        <mxCell id="be_main" value="main.py — REST + SSE + WebSocket&#10;/api/health · /api/agents · /api/stock/{ticker}&#10;/api/debate/stream (SSE, 10s keepalive) · /api/debate (POST)&#10;+ auth.py (optional OIDC JWT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="190" width="460" height="82" as="geometry" />
        </mxCell>
        <mxCell id="be_orch" value="orchestrator.py — 3-phase debate engine&#10;① Independent analysis (agents concurrent, asyncio.gather)&#10;② Debate rounds 1–2 (see public transcript, revise)&#10;③ Consensus — profile-weighted verdict + confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="286" width="460" height="86" as="geometry" />
        </mxCell>
        <mxCell id="be_personas" value="agents/personas.py — 8 personas + profile guidance&#10;Moderator · Fundamental · Chartist · Price · Researcher&#10;Macro · Corporate Actions · Synthesizer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="386" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="be_llm" value="llm/provider.py&#10;mock | bedrock | anthropic&#10;per-role model + auto-fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="470" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="be_data" value="data/ — market · news&#10;technicals · currency&#10;multi-source + fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e6;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="470" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="be_deploy" value="Deploy: image → ECR → App Runner (no 30s cap, streams SSE).  Redeploy = build+push+start-deployment.  Instance role → Bedrock invoke." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontSize=10;fontStyle=2;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="556" width="460" height="70" as="geometry" />
        </mxCell>

        <!-- ================= EXTERNAL: LLM ================= -->
        <mxCell id="bedrock" value="🧠 AWS Bedrock&#10;Claude Opus 4.8&#10;→ Sonnet 4.5 (fallback)&#10;[debate reasoning]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1250" y="180" width="270" height="90" as="geometry" />
        </mxCell>

        <!-- ================= EXTERNAL: MARKET / FUNDAMENTALS ================= -->
        <mxCell id="mkt" value="📈 Prices, charts &amp; fundamentals&#10;Yahoo raw chart API (US + India, real OHLCV, ≥5d)&#10;Finnhub → fundamentals (P/E, EPS, mktcap; US only)&#10;yfinance · Stooq · synthetic (fallbacks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1250" y="300" width="270" height="100" as="geometry" />
        </mxCell>

        <!-- ================= EXTERNAL: CORP ACTIONS ================= -->
        <mxCell id="corp" value="🏛️ Corporate actions&#10;NSE API — India: dividends, splits,&#10;BONUS, BUYBACK, demerger&#10;Yahoo events — US dividends/splits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1250" y="420" width="270" height="90" as="geometry" />
        </mxCell>

        <!-- ================= EXTERNAL: NEWS ================= -->
        <mxCell id="news" value="📰 News (clickable sources)&#10;Finnhub — US company + macro/general&#10;GNews — company by name (India + all)&#10;→ synthetic fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1250" y="530" width="270" height="90" as="geometry" />
        </mxCell>

        <!-- ================= EDGES ================= -->
        <mxCell id="e_user_fe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeWidth=2;" edge="1" parent="1" source="user" target="fe">
          <mxGeometry relative="1" as="geometry" />
