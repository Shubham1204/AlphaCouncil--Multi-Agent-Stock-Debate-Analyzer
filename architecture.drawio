        <mxCell id="e_fe_be" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeWidth=2;" edge="1" parent="1" source="fe_hook" target="be_main">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_fe_be_lbl" value="HTTPS · SSE&#10;(stock, agent tokens, consensus)" style="text;html=1;fontSize=10;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="558" y="300" width="90" height="34" as="geometry" />
        </mxCell>

        <mxCell id="e_main_orch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeWidth=1.5;" edge="1" parent="1" source="be_main" target="be_orch">
          <mxGeometry relative="1" as="geometry" />
